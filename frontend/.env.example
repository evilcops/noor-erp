# Database (PostgreSQL — recommended for NOOR ERP)
DATABASE_URL="postgresql://user:password@localhost:5432/noor_erp?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# AWS S3 (Phase 1 — document uploads)
AWS_REGION="me-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
