NODE_ENV=development

# MongoDB connection (single URI — credentials are embedded in the URI)
MONGODB_URI=mongodb://127.0.0.1:27017/noor_erp
# Or Atlas: mongodb+srv://user:pass@cluster.mongodb.net/noor_erp?retryWrites=true&w=majority

# Local dev without MongoDB installed (file-backed in-memory DB at frontend/.data/mongo)
# USE_MEMORY_DB=true

JWT_SECRET=your-super-secret-key-change-this-min-32-chars
JWT_REFRESH_SECRET=another-secret-key-change-this-min-32-chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

BCRYPT_ROUNDS=10

# Dev-only: auto-created on first API request if missing
ADMIN_EMAIL=admin@noor.om
ADMIN_PASSWORD=Password123!

# Mail (Gmail / SMTP) — used when sending purchase orders to suppliers
APP_NAME=NOOR ERP
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=your@gmail.com
MAIL_FROM_NAME="${APP_NAME}"
