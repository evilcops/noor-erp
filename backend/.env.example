NODE_ENV=development
PORT=5000

MONGODB_USER=your_atlas_db_user
MONGODB_PASSWORD=your_atlas_db_password
MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
MONGODB_DB=noor_erp
# Option A: MongoDB Atlas (whitelist your IP in Atlas → Network Access)
MONGODB_URI=mongodb+srv://your_atlas_db_user:your_atlas_db_password@cluster0.xxxxx.mongodb.net/noor_erp?retryWrites=true&w=majority

# Option B: Local in-memory DB — no Atlas needed (dev only, data resets on restart)
# USE_MEMORY_DB=true

# Option C: Local MongoDB install
# MONGODB_URI=mongodb://127.0.0.1:27017/noor_erp

JWT_SECRET=your-super-secret-key-change-this-min-32-chars
JWT_REFRESH_SECRET=another-secret-key-change-this-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=10

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@noorerp.com

AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=noor-erp-documents
AWS_REGION=me-south-1

CORS_ORIGIN=http://localhost:3000

# Dev-only: auto-created on server start if missing (see bootstrap.service.ts)
ADMIN_EMAIL=admin@noor.om
ADMIN_PASSWORD=Password123!
